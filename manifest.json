{
  "manifest_version": 3,
  "name": "X Post Collector",
  "version": "2.0.0",
  "description": "Auto-collect X/Twitter posts by customizable keywords. Send to Google Sheets via GAS webhook or Sheets API.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Post Collector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}